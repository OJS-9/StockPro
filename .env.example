# Copy to `.env` and fill in values. Never commit `.env`.

# --- Flask ---
FLASK_SECRET_KEY=generate-a-long-random-string

# Optional: per-IP rate limits for research/report routes (flask-limiter syntax, e.g. "30 per hour")
# STOCKPRO_RATE_LIMIT_RESEARCH=30 per hour
# STOCKPRO_RATE_LIMIT_REPORT_GEN=15 per hour
# STOCKPRO_RATE_LIMIT_GENERATE_REPORT=20 per hour
# STOCKPRO_RATE_LIMIT_POPUP_START=60 per hour
# STOCKPRO_RATE_LIMIT_CONTINUE=60 per hour
# STOCKPRO_RATE_LIMIT_CHAT_REPORT=40 per hour

# WebSocket /ws/prices: max symbols per client message (default 50, max 200)
# STOCKPRO_WS_MAX_SYMBOLS=50

# Price alerts: run evaluation after each price_cache upsert (default true; pytest sets false)
# STOCKPRO_ALERT_EVAL_ENABLED=true
# Minimum seconds between repeat triggers for the same alert (default 3600)
# STOCKPRO_ALERT_COOLDOWN_SEC=3600

# --- Database (Supabase: Project Settings → Database → Connection string, URI format) ---
# Use the "Transaction" pooler URL for server apps when possible.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Optional: explicit Supabase project URL + anon key if you add supabase-py client usage
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key

# --- Clerk authentication ---
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_JWT_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# --- Google Gemini (research + embeddings) ---
GEMINI_API_KEY=

# --- LangSmith (optional tracing) ---
LANGCHAIN_TRACING_V2=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=stockpro

# --- Market data (Alpha Vantage, etc.; may also be configured via mcp.json) ---
ALPHA_VANTAGE_API_KEY=

# --- Nimble (optional web extraction) ---
NIMBLE_API_KEY=

# --- OpenAI (optional; legacy scripts only) ---
OPENAI_API_KEY=

# --- Alpaca (Phase 2 brokerage API; optional until integrated) ---
# APCA_API_KEY_ID=
# APCA_API_SECRET_KEY=
# ALPACA_BASE_URL=https://paper-api.alpaca.markets
